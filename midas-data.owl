    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000000 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000000">
        <MIDAS_DATA000003>A medical diagnosis associated with a given outbreak or dataset related to that outbreak. Usually will refer to an ICD, NCIT, UMLS, or similar code.</MIDAS_DATA000003>
        <rdfs:comment></rdfs:comment>
        <rdfs:label xml:lang="en">Diagnosis</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000004 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000004">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000000"/>
        <MIDAS_DATA000003>Associated with the 2019-2020 COVID-19 outbreak.</MIDAS_DATA000003>
        <rdfs:label xml:lang="en">COVID-19</rdfs:label>
        <rdfs:seeAlso>ICD Code U07.1</rdfs:seeAlso>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000005 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000005">
        <MIDAS_DATA000003>The &quot;domain&quot; of the entity - specifically, the focus of the data contained therein.</MIDAS_DATA000003>
        <rdfs:label xml:lang="en">Scale</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000007 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000007">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000005"/>
        <MIDAS_DATA000003>Collections of entities from the research literature, or derived from the literature.</MIDAS_DATA000003>
        <rdfs:label xml:lang="en">Literature</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000008 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000008">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000005"/>
        <MIDAS_DATA000003>Items referring to sequence-level data, including genomics, microbiomics, proteomics, etc.</MIDAS_DATA000003>
        <rdfs:label xml:lang="en">Molecular</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000009 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000009">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000005"/>
        <MIDAS_DATA000003>Items corresponding to entire populations or subpopulations. Might be geographically or temporally temporally limited.</MIDAS_DATA000003>
        <rdfs:label xml:lang="en">Population</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000010 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000010">
        <MIDAS_DATA000003>Descriptors of the data found in the dataset - broadly categorizing the entries that might be annotated with this model</MIDAS_DATA000003>
        <rdfs:label xml:lang="en">Type</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000011 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000011">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000010"/>
        <MIDAS_DATA000003>A collection of links to other data items, often found in external repositories. No claims are made as to the format or consistency of the items associated with those links.</MIDAS_DATA000003>
        <rdfs:comment>Probably should link to some external dataset.</rdfs:comment>
        <rdfs:label xml:lang="en">Catalog</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000012 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000012">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000009"/>
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000010"/>
        <MIDAS_DATA000003>An interactive display, usually in the form of a web page, that provides a summary of the current state of some dataset, usually from multiple perspectives. May include both counrs and forecats.</MIDAS_DATA000003>
        <rdfs:comment>link to some existing ontological term?</rdfs:comment>
        <rdfs:label xml:lang="en">Dashboard</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000013 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000013">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000008"/>
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000010"/>
        <MIDAS_DATA000003>An executable software library, tool, or package, usually with source code.</MIDAS_DATA000003>
        <rdfs:comment>link to some external entity?</rdfs:comment>
        <rdfs:label xml:lang="en">Software</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000014 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000014">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000010"/>
        <MIDAS_DATA000003>A collection of data presented in a formatted and defined manner, along with metadata enabling interpretation of that data. Might be one of the elements in a catalog or repository</MIDAS_DATA000003>
        <rdfs:comment>is there some existing external definition to tie this to?</rdfs:comment>
        <rdfs:label xml:lang="en">Dataset</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000015 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000015">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000008"/>
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000011"/>
        <MIDAS_DATA000003>Data on human genetics and suceptibility to COVID</MIDAS_DATA000003>
        <rdfs:comment>Did we have some other name in mind here?</rdfs:comment>
        <rdfs:label xml:lang="en">Host Genetics</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000016 -->

    <owl:Class rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000016">
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000009"/>
        <rdfs:subClassOf rdf:resource="http://midasnetwork.us/datasets#MIDAS_DATA000012"/>
        <MIDAS_DATA000003>Dashboard displaying cases, deaths, and other details, usually by region and date.</MIDAS_DATA000003>
        <rdfs:label xml:lang="en">Case Counts</rdfs:label>
    </owl:Class>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000017 -->

