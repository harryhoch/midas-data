        <rdfs:label xml:lang="en">Definition</rdfs:label>
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2000/01/rdf-schema#isDefinedBy"/>
    </owl:AnnotationProperty>
    


    <!-- http://midasnetwork.us/datasets#MIDAS_DATA000003 -->

    <owl:AnnotationProperty rdf:about="http://midasnetwork.us/datasets#MIDAS_DATA000003">
        <rdfs:label xml:lang="en">definition</rdfs:label>
    </owl:AnnotationProperty>
    


